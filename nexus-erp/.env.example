# ─── NEXUS ERP — Variáveis de ambiente (Express / server.js) ───
# Copie para `.env` e ajuste. NUNCA comite o `.env` real.

# Porta do servidor
PORT=3002

# Caminho do banco SQLite (use :memory: em testes)
DB_PATH=./nexus.db

# Senha inicial usada para semear/migrar o admin e novos usuários sem senha.
# OBRIGATÓRIO definir em produção (sem isso, usa um default de dev e avisa).
SEED_PASSWORD=troque-esta-senha

# Email do admin inicial (opcional)
ADMIN_EMAIL=admin@fraseralexander.com.br

# Origens permitidas para CORS, separadas por vírgula (sem curinga "*").
ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# ─── Backend Cloudflare Worker (nexus-cf) — definir como secrets ───
# Configure via: `wrangler secret put JWT_SECRET` e `wrangler secret put SEED_PASSWORD`
# JWT_SECRET     -> segredo HS256 (mín. 16 chars). Sem ele, o Worker falha fechado.
# SEED_PASSWORD  -> senha inicial do seed. Sem ela, uma senha aleatória é gerada e
#                   logada (visível em `wrangler tail`).
